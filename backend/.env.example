APP_NAME=inspection-report-core-api
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

SECRET_KEY=change-me-before-deploy
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/inspection_report
REDIS_URL=redis://localhost:6379/0

OBJECT_STORAGE_ENDPOINT=localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=inspection-report
OBJECT_STORAGE_SECURE=false

AI_TASK_QUEUE=parse-jobs

